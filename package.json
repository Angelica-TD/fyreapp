{
  "name": "fyreapp",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "npm run css:build",
    "css:watch": "sass --watch FyreFrontend/scss/bootstrap.custom.scss:wwwroot/css/bootstrap.custom.css --load-path=node_modules --style=expanded --source-map",
    "css:build": "sass FyreFrontend/scss/bootstrap.custom.scss:wwwroot/css/bootstrap.custom.css --load-path=node_modules --style=compressed --no-source-map"
  },

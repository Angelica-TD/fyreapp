@{
    var crumbs = ViewData["Breadcrumbs"] as IReadOnlyList<(string Text, string? Url)>;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FyreApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/bootstrap.custom.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FyreApp.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/logo.png" />
    <link rel="icon" type="image/png" href="~/logo.png" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @* =====================================================================
         TOP NAVBAR
         - Always visible at all breakpoints
         - On mobile/tablet (< lg): shows hamburger that opens offcanvas
         - On desktop (>= lg):      shows brand + sidebar toggle button
         ===================================================================== *@
    <header class="app-header bg-white border-bottom">
        <div class="container-fluid px-3">
            <nav class="navbar navbar-expand-lg px-0">

                @* Offcanvas toggle: visible only below lg *@
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <button class="navbar-toggler border-0 me-2"
                            type="button"
                            data-bs-toggle="offcanvas"
                            data-bs-target="#offcanvasNav"
                            aria-controls="offcanvasNav"
                            aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                }

                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">
                    FyreApp
                </a>

                @* Right-side items in the top bar at desktop *@
                <div class="ms-auto d-flex align-items-center gap-2">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <span class="text-muted small d-none d-lg-inline">@User.Identity.Name</span>
                        <partial name="_LogoutButton" />
                    }
                    else
                    {
                        <a class="btn btn-primary btn-sm" asp-area="Identity" asp-page="/Account/Login">Login</a>
                    }
                </div>

            </nav>
        </div>

    </header>

    @* =====================================================================
         OFFCANVAS NAV (mobile/tablet < lg)
         Renders the same _Sidebar partial so nav is always in sync
         ===================================================================== *@
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <div class="offcanvas offcanvas-start"
             tabindex="-1"
             id="offcanvasNav"
             aria-labelledby="offcanvasNavLabel">
            <div class="offcanvas-header border-bottom">
                <span class="fw-semibold" id="offcanvasNavLabel">FyreApp</span>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body p-0">
                <partial name="~/Views/Components/_Sidebar.cshtml" />
            </div>
        </div>
    }

    @* =====================================================================
         PAGE BODY: sidebar + main content side by side
         ===================================================================== *@
    <div class="app-body">

        @if (User.Identity?.IsAuthenticated ?? false)
        {
            @* Sidebar: only rendered (and visible) at lg+ *@
            <aside id="appSidebar" class="app-sidebar d-none d-lg-flex">
                <partial name="~/Views/Components/_Sidebar.cshtml" />
            </aside>
        }

        <main role="main" class="app-main">
            <div class="app-main-inner d-flex flex-column gap-3">
                @if (!(ViewData["HideBreadcrumb"] as bool? ?? false))
                {
                    @await Html.PartialAsync("_Breadcrumbs", crumbs ?? Array.Empty<(string, string?)>())
                }
                @RenderBody()
            </div>
        </main>

    </div>

    <footer class="app-footer border-top text-muted">
        <div class="container-fluid px-3">
            &copy; @DateTime.Now.Year FyreApp &mdash;
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

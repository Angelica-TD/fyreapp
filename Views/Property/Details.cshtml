@model FyreApp.Models.Site

@{
    ViewData["Title"] = "Site Details";
    var intervals = ViewBag.Intervals as List<FyreApp.Models.MaintenanceInterval>;
}

<h1>@Model.Name</h1>

<p>
    <strong>Client:</strong>
    <a asp-controller="Clients"
       asp-action="Details"
       asp-route-id="@Model.Client.Id">
        @Model.Client.Name
    </a>
</p>

<hr />

<h2>Maintenance Schedule</h2>

<a class="btn btn-primary"
   asp-controller="Task"
   asp-action="Create"
   asp-route-clientId="@Model.ClientId"
   asp-route-siteId="@Model.Id">
    Add task
</a>


@if (Model.MaintenanceSchedules.Any())
{
    var schedule = Model.MaintenanceSchedules.First();

    <form asp-controller="MaintenanceSchedules" asp-action="Upsert" method="post" class="row g-3">
        <input type="hidden" name="scheduleId" value="@schedule.Id" />
        <input type="hidden" name="targetType" value="Site" />
        <input type="hidden" name="targetId" value="@Model.Id" />

        <div class="col-md-4">
            <label class="form-label">Start Date</label>
            <input type="date" name="startDate" class="form-control" value="@schedule.StartDate.ToString("yyyy-MM-dd")" required />
        </div>
        <div class="col-md-4">
            <label class="form-label">Interval</label>
            <select name="intervalId" class="form-select" required>
                @foreach(var interval in intervals)
                {
                    <option value="@interval.Id" selected="@(interval.Id == schedule.MaintenanceIntervalId ? "selected" : null)">
                        @interval.Name
                    </option>
                }
            </select>
        </div>

        <div class="col-md-4 align-self-end">
            <button type="submit" class="btn btn-primary">Save Schedule</button>
        </div>
    </form>
    
    <p class="mt-2"><strong>Next Maintenance:</strong> @schedule.NextRunDate.ToShortDateString()</p>
}
else
{
    <form asp-controller="MaintenanceSchedules" asp-action="Upsert" method="post" class="row g-3">
        <input type="hidden" name="scheduleId" value="0" />
        <input type="hidden" name="targetType" value="Site" />
        <input type="hidden" name="targetId" value="@Model.Id" />
        <div class="col-md-4">
            <label class="form-label">Start Date</label>
            <input type="date" name="startDate" class="form-control" value="@DateTime.UtcNow.ToString("yyyy-MM-dd")" required />
        </div>

        <div class="col-md-4">
            <label class="form-label">Interval</label>
            <select name="intervalId" class="form-select" required>
                @foreach(var interval in intervals)
                {
                    <option value="@interval.Id">@interval.Name</option>
                }
            </select>
        </div>

        <div class="col-md-4 align-self-end">
            <button type="submit" class="btn btn-success">Create Schedule</button>
        </div>
    </form>
}

<hr />


<h3>Assets</h3>

@if (!Model.Assets.Any())
{
    <p class="text-muted">No assets found for this site.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Asset Name</th>
                <th>Types</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
@foreach (var asset in Model.Assets)
{
            <tr>
                <td>@asset.Name</td>
                <td>
@foreach (var type in asset.AssetTypes)
{
                    <span class="badge bg-secondary me-1">@type.Name</span>
}
                </td>
                <td>
                    <a asp-controller="Assets"
                       asp-action="Details"
                       asp-route-id="@asset.Id">
                        View Asset
                    </a>
                </td>
            </tr>
}
        </tbody>
    </table>
}

<a asp-controller="Clients"
   asp-action="Details"
   asp-route-id="@Model.ClientId"
   class="btn btn-secondary">
    ← Back to Client
</a>

@using FyreApp.Infrastructure
@model FyreApp.ViewModels.Clients.ClientDetailsVm

@inject IConfiguration Config
@{
    var googleKey = Config["GoogleMaps:BrowserKey"];
}

@{
    ViewData["Title"] = "Client Details";
    var c = Model.Client;
    var showEdit = Model.OpenEdit;
}

@section Styles{
    <style>
    .pac-container {
        z-index: 2000 !important;
    }
    </style>
}

<div class="card">

    <div class="card-header">
        <div class="d-flex align-items-center justify-content-between">
            <h5>@c.Name</h5>

            
            <button class="btn text-uppercase text-primary"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#editClientCollapse"
                    aria-expanded="@(showEdit.ToString().ToLowerInvariant())"
                    aria-controls="editClientCollapse">
                    <i class="bi bi-pencil-square"></i>
                Edit
            </button>

        </div>
    </div>

    @await Html.PartialAsync("_FieldList", UiFieldBuilder.Build(c))
    
</div>



@if (TempData["Success"] is string okMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @okMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] is string errMsg)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}


<div class="d-flex justify-content-between">
    <div class="d-flex gap-2 mb-3">
        <a asp-action="Index" class="btn btn-secondary">← Back to Clients</a>

        <button class="btn btn-primary"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#editClientCollapse"
                aria-expanded="@(showEdit.ToString().ToLowerInvariant())"
                aria-controls="editClientCollapse">
            Edit client
        </button>

    </div>
    <form asp-action="Delete" asp-controller="Clients" asp-route-id="@c.Id" method="post">
        <button class="icon-link text-danger" type="submit">
            <i class="bi bi-trash3"></i> Delete
        </button>
    </form>
</div>

<div class="collapse @(showEdit ? "show" : "")" id="editClientCollapse">
    <div class="card mb-4">
        <div class="card-body">

            <h5 class="card-title mb-3">Edit client</h5>

            <form asp-action="Update" asp-controller="Clients" asp-route-id="@c.Id" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label" asp-for="Edit.Name">Name</label>
                    <input class="form-control" asp-for="Edit.Name" required />
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" asp-for="Edit.Active" />
                    <label class="form-check-label" asp-for="Edit.Active">Active</label>
                </div>

                <hr />

                <h6 class="mt-3">Primary contact</h6>
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label" asp-for="Edit.PrimaryContactName">Contact name</label>
                        <input class="form-control" asp-for="Edit.PrimaryContactName" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="Edit.PrimaryContactEmail">Email</label>
                        <input class="form-control" asp-for="Edit.PrimaryContactEmail" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="Edit.PrimaryContactMobile">Mobile</label>
                        <input class="form-control" asp-for="Edit.PrimaryContactMobile" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="Edit.PrimaryContactCcEmail">CC email</label>
                        <input class="form-control" asp-for="Edit.PrimaryContactCcEmail" />
                    </div>
                </div>

                <h6 class="mt-4">Primary address</h6>
                <div class="row g-2">
                    <div class="col-md-12">
                        <label class="form-label" asp-for="Edit.PrimaryContactAddress">Address</label>
                        <input class="form-control" asp-for="Edit.PrimaryContactAddress" />
                    </div>
                </div>

                <h6 class="mt-4">Billing</h6>
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label" asp-for="Edit.BillingName">Billing name</label>
                        <input class="form-control" asp-for="Edit.BillingName" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="Edit.BillingAttentionTo">Attention to</label>
                        <input class="form-control" asp-for="Edit.BillingAttentionTo" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="Edit.BillingEmail">Billing email</label>
                        <input class="form-control" asp-for="Edit.BillingEmail" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" asp-for="Edit.BillingCcEmail">Billing CC email</label>
                        <input class="form-control" asp-for="Edit.BillingCcEmail" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label" asp-for="Edit.BillingAddress">Billing address</label>
                        <input class="form-control" asp-for="Edit.BillingAddress" />
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-success">Save changes</button>

                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-bs-toggle="collapse"
                            data-bs-target="#editClientCollapse">
                        Cancel
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<hr />

<h3>Properties</h3>

@if (User.IsInRole("Admin"))
{
    <button class="btn btn-primary"
            data-bs-toggle="modal"
            data-bs-target="#createSiteModal">
        <i class="bi bi-plus-lg"></i> Add Property
    </button>
}


<div class="modal fade" id="createSiteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">

            <form asp-controller="Property"
                  asp-action="Create"
                  method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" name="clientId" value="@Model.Client.Id" />

                <div class="modal-header">
                    <h5 class="modal-title">Add a New Property for @c.Name</h5>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Property Name</label>
                        <input name="name"
                               class="form-control"
                               required
                               autofocus />
                    </div>

                    <input type="hidden" id="GooglePlaceId" name="Google.PlaceId" />
                    <input type="hidden" id="GoogleFormattedAddress" name="Google.FormattedAddress" />

                    <div class="mb-3">
                        <label class="form-label" for="SiteAddressSearch">Address</label>
                        <input class="form-control"
                            id="SiteAddressSearch"
                            type="text"
                            placeholder="Start typing an Australian address…"
                            autocomplete="off" />
                    </div>

                    <button type="button" class="btn btn-link px-0" id="btnManualAddress">
                        Can't find the address? Enter manually
                    </button>

                    <div id="manualAddressPanel" class="mt-2 d-none">
                        <div class="mb-2">
                            <label class="form-label" for="AddressLine1">Address line 1</label>
                            <input class="form-control" id="AddressLine1" name="Manual.AddressLine1" maxlength="200" />
                        </div>

                        <div class="mb-2">
                            <label class="form-label" for="AddressLine2">Address line 2</label>
                            <input class="form-control" id="AddressLine2" name="Manual.AddressLine2" maxlength="200" />
                        </div>

                        <div class="row g-2">
                            <div class="col-md-5">
                                <label class="form-label" for="Suburb">Suburb</label>
                                <input class="form-control" id="Suburb" name="Manual.Suburb" maxlength="80" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label" for="State">State</label>
                                <input class="form-control" id="State" name="Manual.State" maxlength="20" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="Postcode">Postcode</label>
                                <input class="form-control" id="Postcode" name="Manual.Postcode" maxlength="10" />
                            </div>
                        </div>

                    </div>
                    
                </div>

                <div class="modal-footer">
                    <button type="submit"
                            class="btn btn-primary">
                        Save
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>


@if (!c.Sites.Any())
{
    <p class="text-muted">No sites found for this client.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Property Name</th>
                <th>Assets</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var site in c.Sites)
        {
            <tr>
                <td>@site.Name</td>
                <td>@site.Assets.Count</td>
                <td>
                    <a asp-controller="Property" asp-action="Details" asp-route-id="@site.Id">
                        View Property
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
@section Scripts {

<script>
    document.getElementById("btnManualAddress")?.addEventListener("click", () => {
    document.getElementById("manualAddressPanel")?.classList.remove("d-none");
    document.getElementById("GooglePlaceId").value = "";
    document.getElementById("GoogleFormattedAddress").value = "";
    });
  function initGooglePlaces() {
    console.log("initGooglePlaces called", !!window.google?.maps?.places);

    const modalEl = document.getElementById("createSiteModal");
    const addressInput = document.getElementById("SiteAddressSearch");
    const googleFormattedAddress = document.getElementById("GoogleFormattedAddress");
    const googlePlaceId = document.getElementById("GooglePlaceId");

    if (!modalEl || !addressInput) return;

    let ac;
    modalEl.addEventListener("shown.bs.modal", () => {
      console.log("modal shown, attaching autocomplete");

      if (ac) return;

      ac = new google.maps.places.Autocomplete(addressInput, {
        fields: ["place_id", "formatted_address"],
        types: ["address"]
        });

        ac.setComponentRestrictions({ country: ["au"] });

        ac.addListener("place_changed", () => {
            const place = ac.getPlace();
            if (!place?.place_id) return;

            googlePlaceId.value = place.place_id;
            googleFormattedAddress.value = place.formatted_address ?? "";
        });
    });
  }
</script>

<script
  src="https://maps.googleapis.com/maps/api/js?key=@googleKey&libraries=places&callback=initGooglePlaces"
  async defer>
</script>

}
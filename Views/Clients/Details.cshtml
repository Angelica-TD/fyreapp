@model FyreApp.ViewModels.Clients.ClientDetailsVm

@{
    ViewData["Title"] = "Client Details";
    var c = Model.Client;
    var showEdit = Model.OpenEdit;
}

<h1>@c.Name</h1>

@if (TempData["Success"] is string okMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @okMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] is string errMsg)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex gap-2 mb-3">
    <a asp-action="Index" class="btn btn-secondary">← Back to Clients</a>

    <button class="btn btn-primary"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#editClientCollapse"
            aria-expanded="@(showEdit.ToString().ToLowerInvariant())"
            aria-controls="editClientCollapse">
        Edit client
    </button>
</div>

<div class="collapse @(showEdit ? "show" : "")" id="editClientCollapse">
    <div class="card mb-4">
        <div class="card-body">

            <h5 class="card-title mb-3">Edit client</h5>

            <form asp-action="Update" asp-controller="Clients" asp-route-id="@c.Id" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label" for="Edit_Name">Name</label>
                    <input class="form-control" id="Edit_Name" name="Name" value="@Model.Edit.Name" required />
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="Edit_Active" name="Active" value="true"
                           @(Model.Edit.Active ? "checked" : "") />
                    <input type="hidden" name="Active" value="false" />
                    <label class="form-check-label" for="Edit_Active">Active</label>
                </div>

                <hr />

                <h6 class="mt-3">Primary contact</h6>
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label">Contact name</label>
                        <input class="form-control" name="PrimaryContactName" value="@Model.Edit.PrimaryContactName" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input class="form-control" name="PrimaryContactEmail" value="@Model.Edit.PrimaryContactEmail" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Mobile</label>
                        <input class="form-control" name="PrimaryContactMobile" value="@Model.Edit.PrimaryContactMobile" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">CC email</label>
                        <input class="form-control" name="PrimaryContactCcEmail" value="@Model.Edit.PrimaryContactCcEmail" />
                    </div>
                </div>

                <h6 class="mt-4">Primary address</h6>
                <div class="row g-2">
                    <div class="col-md-12">
                        <label class="form-label">Street</label>
                        <input class="form-control" name="PrimaryContactAddress" value="@Model.Edit.PrimaryContactAddress" />
                    </div>
                </div>

                <h6 class="mt-4">Billing</h6>
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label">Billing name</label>
                        <input class="form-control" name="BillingName" value="@Model.Edit.BillingName" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Attention to</label>
                        <input class="form-control" name="BillingAttentionTo" value="@Model.Edit.BillingAttentionTo" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Billing email</label>
                        <input class="form-control" name="BillingEmail" value="@Model.Edit.BillingEmail" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Billing CC email</label>
                        <input class="form-control" name="BillingCcEmail" value="@Model.Edit.BillingCcEmail" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label">Billing address</label>
                        <input class="form-control" name="BillingAddress" value="@Model.Edit.BillingAddress" />
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-success">Save changes</button>

                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-bs-toggle="collapse"
                            data-bs-target="#editClientCollapse">
                        Cancel
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

<hr />

<h3>Sites</h3>

@if (!c.Sites.Any())
{
    <p class="text-muted">No sites found for this client.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Site Name</th>
                <th>Assets</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var site in c.Sites)
        {
            <tr>
                <td>@site.Name</td>
                <td>@site.Assets.Count</td>
                <td>
                    <a asp-controller="Sites" asp-action="Details" asp-route-id="@site.Id">
                        View Site
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@using FyreApp.Infrastructure
@model FyreApp.ViewModels.Clients.ClientDetailsVm

@inject IConfiguration Config
@{
    var googleKey = Config["GoogleMaps:BrowserKey"] ?? "";
}

@{
    ViewData["Title"] = "Client Details";
    var c = Model.Client;
    var showEdit = Model.OpenEdit;
}

<div class="card">
    <div class="card-header">
        <div class="d-flex align-items-center justify-content-between">
            <h5>@c.Name</h5>
            <button class="btn text-uppercase text-primary"
                    type="button"
                    data-bs-toggle="modal"
                    data-bs-target="#editClientModal">
                <i class="bi bi-pencil-square"></i> Edit
            </button>
        </div>
    </div>

    @await Html.PartialAsync("_FieldList", UiFieldBuilder.Build(c))
</div>

@if (TempData["Success"] is string okMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @okMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] is string errMsg)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between mt-3">
    <div class="d-flex gap-2 mb-3">
        <a asp-action="Index" class="btn btn-secondary">← Back to Clients</a>
        <button class="btn btn-primary"
                type="button"
                data-bs-toggle="modal"
                data-bs-target="#editClientModal">
            Edit client
        </button>
    </div>
    <form asp-action="Delete" asp-controller="Clients" asp-route-id="@c.Id" method="post">
        <button class="icon-link text-danger" type="submit">
            <i class="bi bi-trash3"></i> Delete
        </button>
    </form>
</div>

<div class="modal fade" id="editClientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="Update" asp-controller="Clients" asp-route-id="@c.Id" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title">Edit client</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">

                    <div class="mb-3">
                        <label class="form-label" asp-for="Edit.Name">Name</label>
                        <input class="form-control" asp-for="Edit.Name" required />
                        <span class="text-danger" asp-validation-for="Edit.Name"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" asp-for="Edit.Active" />
                        <label class="form-check-label" asp-for="Edit.Active">Active</label>
                    </div>

                    <hr />

                    <h6>Primary contact</h6>
                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <label class="form-label" asp-for="Edit.PrimaryContactName">Contact name</label>
                            <input class="form-control" asp-for="Edit.PrimaryContactName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="Edit.PrimaryContactEmail">Email</label>
                            <input class="form-control" asp-for="Edit.PrimaryContactEmail" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="Edit.PrimaryContactMobile">Mobile</label>
                            <input class="form-control" asp-for="Edit.PrimaryContactMobile" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="Edit.PrimaryContactCcEmail">CC email</label>
                            <input class="form-control" asp-for="Edit.PrimaryContactCcEmail" />
                        </div>
                    </div>

                    <h6>Primary address</h6>
                    <div class="row g-2 mb-3">
                        <div class="col-md-12">
                            <label class="form-label" asp-for="Edit.PrimaryContactAddress">Address</label>
                            <input class="form-control" asp-for="Edit.PrimaryContactAddress" />
                        </div>
                    </div>

                    <h6>Billing</h6>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label class="form-label" asp-for="Edit.BillingName">Billing name</label>
                            <input class="form-control" asp-for="Edit.BillingName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="Edit.BillingAttentionTo">Attention to</label>
                            <input class="form-control" asp-for="Edit.BillingAttentionTo" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="Edit.BillingEmail">Billing email</label>
                            <input class="form-control" asp-for="Edit.BillingEmail" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="Edit.BillingCcEmail">Billing CC email</label>
                            <input class="form-control" asp-for="Edit.BillingCcEmail" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label" asp-for="Edit.BillingAddress">Billing address</label>
                            <input class="form-control" asp-for="Edit.BillingAddress" />
                        </div>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save changes</button>
                </div>

            </form>
        </div>
    </div>
</div>

<hr />

<h3>Properties</h3>

@if (User.IsInRole("Admin"))
{
    <button class="btn btn-primary"
            data-bs-toggle="modal"
            data-bs-target="#createSiteModal">
        <i class="bi bi-plus-lg"></i> Add Property
    </button>
}

@await Html.PartialAsync("_CreatePropertyModal",
    new FyreApp.ViewModels.Sites.CreatePropertyModalVm
    {
        ClientId = Model.Client.Id,
        ClientName = Model.Client.Name,
        ModalId = "createSiteModal",
        IdPrefix = "clientDetailsCreateSite",
        ShowClientNameInTitle = true,
        GoogleBrowserKey = googleKey
    })

@if (!c.Sites.Any())
{
    <p class="text-muted">No sites found for this client.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Property Name</th>
                <th>Assets</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var site in c.Sites)
        {
            <tr>
                <td>@site.Name</td>
                <td>@site.Assets.Count</td>
                <td>
                    <a asp-controller="Property" asp-action="Details" asp-route-id="@site.Id">
                        View Property
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    @if (showEdit)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                bootstrap.Modal.getOrCreateInstance(document.getElementById("editClientModal")).show();
            });
        </script>
    }
}

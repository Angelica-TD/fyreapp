@model FyreApp.ViewModels.Clients.CreateClientVm

<div class="modal fade" id="createClientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">

            @if(Model.ExistingClient != null)
            {

                <div class="modal-header">
                    <h5 class="modal-title">Add New Client</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <div>
                        A client named
                        <strong>@Model.ExistingClient.ClientName</strong>
                        already exists.
                    </div>
                </div>

                <div class="modal-footer">
                    @* <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button> *@
                    <a asp-controller="Clients"
                        asp-action="Details"
                        asp-route-id="@Model.ExistingClient.ClientId"
                        class="btn btn-sm btn-outline-primary">
                        View Client
                    </a>
                </div>

                

                
            }
            else
            {
                <form asp-action="Create" asp-controller="Clients" method="post">
                    @Html.AntiForgeryToken()

                    <div class="modal-header">
                        <h5 class="modal-title">Add New Client</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" autocomplete="off" id="createClientName" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>

                </form>
            }


        </div>
    </div>
</div>

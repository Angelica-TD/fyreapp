@model FyreApp.ViewModels.Clients.CreateClientVm

<div class="modal fade" id="createClientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">

            @if(Model.ExistingClient != null)
            {

                <div class="modal-header">
                    <h5 class="modal-title">Add New Client</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <div>
                        A client named
                        <strong>@Model.ExistingClient.ClientName</strong>
                        already exists.
                    </div>
                </div>

                <div class="modal-footer">
                    @* <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button> *@
                    <a asp-controller="Clients"
                        asp-action="Details"
                        asp-route-id="@Model.ExistingClient.ClientId"
                        class="btn btn-sm btn-outline-primary">
                        View Client
                    </a>
                </div>

                

                
            }
            else
            {
                <form asp-action="Create" asp-controller="Clients" method="post">
                    @Html.AntiForgeryToken()

                    <div class="modal-header">
                        <h5 class="modal-title">Add New Client</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Client Name</label>
                            <input asp-for="Name" class="form-control" autocomplete="off" id="createClientName" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="PrimaryContactName" class="form-label">Primary Contact Name</label>
                            <input asp-for="PrimaryContactName" class="form-control" autocomplete="off" />
                            <span asp-validation-for="PrimaryContactName" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="PrimaryContactMobile" class="form-label">Mobile</label>
                            <input asp-for="PrimaryContactMobile" class="form-control" type="tel" autocomplete="off" />
                            <span asp-validation-for="PrimaryContactMobile" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="PrimaryContactEmail" class="form-label">Email</label>
                            <input asp-for="PrimaryContactEmail" class="form-control" type="email" autocomplete="off" />
                            <span asp-validation-for="PrimaryContactEmail" class="text-danger small"></span>
                            <div class="form-text">Mobile or email is required.</div>
                        </div>
                        <div class="text-danger small d-none js-contact-error">Please provide a mobile number or email address.</div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>

                </form>
                <script>
                (function () {
                    const form = document.querySelector('#createClientModal form');
                    if (!form) return;
                    const emailInput  = form.querySelector('[name="PrimaryContactEmail"]');
                    const mobileInput = form.querySelector('[name="PrimaryContactMobile"]');

                    form.addEventListener('submit', e => {
                        const hasEmail  = emailInput?.value.trim();
                        const hasMobile = mobileInput?.value.trim();
                        if (!hasEmail && !hasMobile) {
                            e.preventDefault();
                            emailInput?.classList.add('is-invalid');
                            mobileInput?.classList.add('is-invalid');
                            const msg = form.querySelector('.js-contact-error');
                            if (msg) msg.classList.remove('d-none');
                        }
                    });

                    [emailInput, mobileInput].forEach(el => el?.addEventListener('input', () => {
                        if (emailInput?.value.trim() || mobileInput?.value.trim()) {
                            emailInput?.classList.remove('is-invalid');
                            mobileInput?.classList.remove('is-invalid');
                            form.querySelector('.js-contact-error')?.classList.add('d-none');
                        }
                    }));
                })();
                </script>
            }


        </div>
    </div>
</div>

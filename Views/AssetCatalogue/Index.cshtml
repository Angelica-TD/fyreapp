@model IEnumerable<FyreApp.Models.AssetCatalogue>

@{
    ViewData["Title"] = "Asset Catalogue";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Asset Catalogue</h1>
    <span class="text-muted small">@Model.Count() items</span>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form asp-action="Create" method="post" class="d-flex gap-2 mb-4">
    @Html.AntiForgeryToken()
    <input type="text" name="name" class="form-control" placeholder="New asset name…" required maxlength="200" style="max-width:400px" />
    <button type="submit" class="btn btn-primary">Add</button>
</form>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="align-middle">@item.Name</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Delete \'@item.Name\' from the catalogue?')">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

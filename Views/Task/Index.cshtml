@model FyreApp.ViewModels.Tasks.TaskIndexVm
@using FyreApp.Models

@{
    ViewData["Title"] = "Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Tasks</h1>
    <a asp-action="Create" class="btn btn-primary">+ New Task</a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="get" class="row g-2 mb-4">
    <div class="col-auto">
        <select name="status" class="form-select form-select-sm">
            <option value="">All statuses</option>
            @foreach (var s in Enum.GetValues<ClientTaskStatus>())
            {
                <option value="@s" selected="@(Model.StatusFilter == s.ToString())">@s</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <button class="btn btn-sm btn-outline-secondary" type="submit">Filter</button>
        <a asp-action="Index" class="btn btn-sm btn-link">Clear</a>
    </div>
</form>

@if (!Model.Tasks.Any())
{
    <div class="alert alert-info">No tasks found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Title</th>
                    <th>Client</th>
                    <th>Property</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Due</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.Tasks)
                {
                    <tr>
                        <td>
                            <a asp-action="Details" asp-route-id="@t.Id" class="fw-semibold text-decoration-none">
                                @t.Title
                            </a>
                        </td>
                        <td>@t.ClientName</td>
                        <td>@t.SiteName</td>
                        <td>
                            <span class="badge @PriorityBadge(t.Priority)">@t.Priority</span>
                        </td>
                        <td>
                            <span class="badge @StatusBadge(t.Status)">@t.Status</span>
                        </td>
                        <td>
                            @if (t.DueDate.HasValue)
                            {
                                var due = t.DueDate.Value.ToLocalTime();
                                var overdue = t.Status != ClientTaskStatus.Completed
                                           && t.Status != ClientTaskStatus.Cancelled
                                           && due < DateTime.Now;
                                <span class="@(overdue ? "text-danger fw-semibold" : "")">
                                    @due.ToString("d MMM yyyy")
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@t.Id"
                               class="btn btn-sm btn-outline-secondary">View</a>
                            <a asp-action="Edit" asp-route-id="@t.Id"
                               class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@t.Id"
                               class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@functions {
    static string PriorityBadge(ClientTaskPriority p) => p switch
    {
        ClientTaskPriority.Low    => "bg-secondary",
        ClientTaskPriority.Normal => "bg-primary",
        ClientTaskPriority.High   => "bg-warning text-dark",
        ClientTaskPriority.Urgent => "bg-danger",
        _                         => "bg-secondary"
    };

    static string StatusBadge(ClientTaskStatus s) => s switch
    {
        ClientTaskStatus.Open       => "bg-info text-dark",
        ClientTaskStatus.InProgress => "bg-primary",
        ClientTaskStatus.Blocked    => "bg-warning text-dark",
        ClientTaskStatus.Completed  => "bg-success",
        ClientTaskStatus.Cancelled  => "bg-secondary",
        _                           => "bg-secondary"
    };
}

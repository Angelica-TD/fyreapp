@inject IConfiguration Config
@model FyreApp.ViewModels.Tasks.CreateClientTaskFormVm

@{
    ViewData["Title"] = "Create Task";
}

<h1>Create Task</h1>

<div class="card">
    <div class="card-body">
        <form method="post" asp-controller="Task" asp-action="Create">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label" asp-for="Task.ClientId">Client</label>
                <select class="form-select" asp-for="Task.ClientId" asp-items="Model.Clients" id="ClientId">
                    <option value="">Select a client…</option>
                </select>
                <span class="text-danger" asp-validation-for="Task.ClientId"></span>
            </div>

            <div class="mb-3">
                <label class="form-label" asp-for="Task.SiteId">Property / Site</label>
                <select class="form-select" id="SiteId" asp-for="Task.SiteId" required disabled>
                    <option value="">Select a property…</option>
                    <option value="__new__">+ Add new property…</option>
                </select>
                <span class="text-danger" asp-validation-for="Task.SiteId"></span>
            </div>

            <div class="mb-3">
                <label class="form-label" asp-for="Task.Title">Title</label>
                <input class="form-control" asp-for="Task.Title" maxlength="120" placeholder="Short task description" />
                <span class="text-danger" asp-validation-for="Task.Title"></span>
            </div>

            <div class="mb-3">
                <label class="form-label" asp-for="Task.Description">Description</label>
                <textarea class="form-control" asp-for="Task.Description" rows="4" maxlength="4000"
                          placeholder="Optional detail…"></textarea>
                <span class="text-danger" asp-validation-for="Task.Description"></span>
            </div>

            <div class="mb-3">
                <label class="form-label" asp-for="Task.Priority">Priority</label>
                <select class="form-select" asp-for="Task.Priority"
                        asp-items="Html.GetEnumSelectList<FyreApp.Models.ClientTaskPriority>()">
                </select>
                <span class="text-danger" asp-validation-for="Task.Priority"></span>
            </div>

            <div class="mb-3">
                <label class="form-label" asp-for="Task.DueDateLocal">Due Date</label>
                <input class="form-control" asp-for="Task.DueDateLocal" type="datetime-local" />
                <span class="text-danger" asp-validation-for="Task.DueDateLocal"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create Task</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>

        @await Html.PartialAsync("_CreatePropertyModal",
            new FyreApp.ViewModels.Sites.CreatePropertyModalVm
            {
                ClientId = null,
                ClientName = "",
                ModalId = "taskCreateSiteModal",
                IdPrefix = "taskCreateSite",
                ShowClientNameInTitle = false,
                GoogleBrowserKey = Config["GoogleMaps:BrowserKey"] ?? ""
            })
    </div>
</div>

@section Scripts {
<script>
(function () {
  const NEW_VALUE = "__new__";

  const clientSel  = document.getElementById("ClientId");
  const siteSel    = document.getElementById("SiteId");

  const modalId    = "taskCreateSiteModal";
  const modalEl    = document.getElementById(modalId);
  const modalForm  = modalEl?.querySelector("form.js-create-site-form");
  const modalClientId = modalEl?.querySelector('input[data-role="client-id"]');
  const modalSiteName = modalEl?.querySelector('input[data-role="site-name"]');

  let bsModal = null;
  if (modalEl) bsModal = bootstrap.Modal.getOrCreateInstance(modalEl);

  function ensureAddNewOption() {
    if (!Array.from(siteSel.options).some(o => o.value === NEW_VALUE)) {
      const opt = document.createElement("option");
      opt.value = NEW_VALUE;
      opt.textContent = "+ Add new property…";
      siteSel.appendChild(opt);
    }
  }

  function setSiteOptions(sites) {
    const current = siteSel.value;
    siteSel.innerHTML = '<option value="">Select a property…</option>';
    for (const s of sites) {
      const opt = document.createElement("option");
      opt.value = s.id;
      opt.textContent = s.name;
      siteSel.appendChild(opt);
    }
    ensureAddNewOption();
    siteSel.disabled = false;
    const stillExists = Array.from(siteSel.options).some(o => o.value === current);
    siteSel.value = stillExists ? current : "";
  }

  async function loadSites(clientId) {
    if (!clientId) {
      siteSel.innerHTML = '<option value="">Select a property…</option>';
      ensureAddNewOption();
      siteSel.disabled = true;
      return;
    }
    const res  = await fetch(`/Task/PropertiesForClient?clientId=${encodeURIComponent(clientId)}`,
                             { headers: { "Accept": "application/json" } });
    const data = res.ok ? await res.json() : [];
    setSiteOptions(data);
  }

  clientSel.addEventListener("change", async () => {
    if (modalClientId) modalClientId.value = clientSel.value || "0";
    await loadSites(clientSel.value);
  });

  siteSel.addEventListener("change", () => {
    if (siteSel.value !== NEW_VALUE) return;
    if (!clientSel.value) { siteSel.value = ""; return; }
    if (modalClientId) modalClientId.value = clientSel.value;
    if (modalSiteName)  modalSiteName.value  = "";
    bsModal?.show();
  });

  modalForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const clientId = clientSel.value;
    const hiddenClientId = modalForm.querySelector('input[name="ClientId"]');
    if (hiddenClientId) hiddenClientId.value = clientId || "0";
    if (!clientId) return;

    const submitBtn = modalForm.querySelector('button[type="submit"]');
    if (submitBtn) submitBtn.disabled = true;

    try {
      const body = new URLSearchParams(new FormData(modalForm));
      const res  = await fetch("/Property/CreateAjax", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body
      });
      if (!res.ok) throw new Error(await res.text() || "Could not create property.");
      const created = await res.json();

      const newOpt    = document.createElement("option");
      newOpt.value    = String(created.id);
      newOpt.textContent = created.name;
      const addNewOpt = Array.from(siteSel.options).find(o => o.value === NEW_VALUE);
      if (addNewOpt) siteSel.insertBefore(newOpt, addNewOpt);
      else           siteSel.appendChild(newOpt);

      siteSel.disabled = false;
      siteSel.value    = String(created.id);
      bsModal?.hide();
    } catch (err) {
      alert(err?.message || "Could not create property.");
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });

  ensureAddNewOption();
})();
</script>
}

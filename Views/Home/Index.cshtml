@model FyreApp.ViewModels.Home.HomeIndexVm

@{
    ViewData["Title"] = "Home Page";
}

@if (!User.Identity?.IsAuthenticated ?? true)
{
    ViewData["LoginMessage"] = "Please log in.";
    <partial name="_Login" model="Model" />
}
else if (User.IsInRole("Admin"))
{
    <partial name="_MaintenanceCalendar" />
}
else
{
    ViewData["AccessMessage"] = "You are logged in, but you do not have permission to view the maintenance calendar.";
    <partial name="_AccessRestricted" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

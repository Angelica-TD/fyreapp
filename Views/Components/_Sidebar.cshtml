<nav class="sidebar-nav">
    <ul class="nav nav-pills flex-column gap-1">

        <li class="nav-item text-end">
            @* Desktop sidebar toggle: visible only at lg+ *@
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <button id="sidebarToggle"
                            class="btn btn-sm btn-ghost d-none d-lg-inline-flex align-items-center"
                            aria-label="Toggle sidebar"
                            title="Toggle sidebar">
                        <i class="bi bi-layout-sidebar"></i>
                    </button>
                }
        </li>

        <!-- Home -->
        <li class="nav-item">
            <a class="nav-link sidebar-link"
               asp-controller="Home"
               asp-action="Index"
               nav-active>
                <i class="bi bi-house-door-fill sidebar-icon"></i>
                <span class="sidebar-label">Home</span>
            </a>
        </li>

        <!-- Clients -->
        <li class="nav-item has-subnav">
            <a class="nav-link sidebar-link"
               asp-controller="Clients"
               asp-action="Index"
               nav-active
               nav-active-controller-only>
                <i class="bi bi-people-fill sidebar-icon"></i>
                <span class="sidebar-label">Clients</span>
            </a>
            <ul class="nav flex-column sub-nav ps-4 mt-1">
                <li class="nav-item">
                    <button type="button"
                            class="nav-link sidebar-link sidebar-sublink btn btn-link text-start w-100"
                            data-bs-toggle="modal"
                            data-bs-target="#createClientModal">
                        <i class="bi bi-plus-circle sidebar-icon"></i>
                        <span class="sidebar-label">Add new</span>
                    </button>
                </li>
            </ul>
        </li>

        <!-- Tasks -->
        <li class="nav-item has-subnav">
            <a class="nav-link sidebar-link"
               asp-controller="Task"
               asp-action="Index"
               nav-active
               nav-active-controller-only>
                <i class="bi bi-check2-square sidebar-icon"></i>
                <span class="sidebar-label">Tasks</span>
            </a>
            <ul class="nav flex-column sub-nav ps-4 mt-1">
                <li class="nav-item">
                    <a class="nav-link sidebar-link sidebar-sublink"
                       asp-controller="Task"
                       asp-action="Create">
                        <i class="bi bi-plus-circle sidebar-icon"></i>
                        <span class="sidebar-label">Add new</span>
                    </a>
                </li>
            </ul>
        </li>

        @if (User.IsInRole("Admin"))
        {
            <!-- Users (Admin only) -->
            <li class="nav-item has-subnav">
                <a class="nav-link sidebar-link"
                   asp-controller="Users"
                   asp-action="Index"
                   nav-active
                   nav-active-controller-only>
                    <i class="bi bi-shield-lock-fill sidebar-icon"></i>
                    <span class="sidebar-label">Users</span>
                </a>
                <ul class="nav flex-column sub-nav ps-4 mt-1">
                    <li class="nav-item">
                        <a class="nav-link sidebar-link sidebar-sublink"
                           asp-controller="Users"
                           asp-action="Create">
                            <i class="bi bi-plus-circle sidebar-icon"></i>
                            <span class="sidebar-label">Add new</span>
                        </a>
                    </li>
                </ul>
            </li>
        }

    </ul>
</nav>
